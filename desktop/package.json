{
  "name": "udr-desktop",
  "version": "1.1.3",
  "description": "Universal Dependency Resolver — Desktop App",
  "homepage": "https://github.com/code-with-zeeshan/universal-dependency-resolver",
  "repository": {
    "type": "git",
    "url": "https://github.com/code-with-zeeshan/universal-dependency-resolver.git"
  },
  "license": "MIT",
  "author": {
    "name": "Universal Dependency Resolver Team",
    "email": "team@udr.example.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "dist": "electron-builder --linux --win --mac"
  },
  "build": {
    "appId": "com.udr.desktop",
    "productName": "UDR",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": ["**/*", "!__pycache__/**", "!**/*.pyc"]
      },
      {
        "from": "../backend/dist",
        "to": "backend-bin",
        "filter": ["**/*"]
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Development"
    },
    "win": {
      "target": ["nsis"]
    },
    "mac": {
      "target": ["dmg"]
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}

{
  "name": "udr-desktop",
  "version": "1.3.0",
  "description": "Universal Dependency Resolver \u2014 Desktop App",
  "homepage": "https://github.com/code-with-zeeshan/universal-dependency-resolver",
  "repository": {
    "type": "git",
    "url": "https://github.com/code-with-zeeshan/universal-dependency-resolver.git"
  },
  "license": "MIT",
  "author": {
    "name": "Mohammad Zeeshan",
    "email": "zeeshansayfyebusiness@gmail.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test tests/backend-launcher.test.js",
    "build": "electron-builder",
    "dist:linux": "electron-builder --linux",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist": "electron-builder --linux --win --mac"
  },
  "build": {
    "appId": "com.udr.desktop",
    "productName": "UDR",
    "compression": "maximum",
    "directories": {
      "output": "release",
      "buildResources": "buildResources"
    },
    "files": [
      "main.js",
      "backend-launcher.js",
      "preload.js",
      "index.html",
      "!tests/**"
    ],
    "extraResources": [
      {
        "from": "../backend/dist/udr-backend",
        "to": "backend-bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "buildResources/icon.ico",
      "legalTrademarks": "Universal Dependency Resolver",
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "buildResources/icon.ico",
      "uninstallerIcon": "buildResources/icon.ico",
      "installerHeaderIcon": "buildResources/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UDR",
      "unicode": true,
      "warningsAsErrors": false,
      "runAfterFinish": false,
      "license": "../LICENSE"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "buildResources/icon.icns",
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "dmg": {
      "title": "UDR ${version}",
      "icon": "buildResources/icon.icns",
      "background": "buildResources/background.png",
      "contents": [
        {
          "x": 448,
          "y": 344,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 192,
          "y": 344,
          "type": "file"
        }
      ],
      "window": {
        "width": 640,
        "height": 480
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "buildResources/icon.png",
      "category": "Development",
      "synopsis": "Cross-ecosystem dependency resolver",
      "description": "Resolve dependencies across PyPI, npm, Cargo, Conda, Maven, and more. Detect conflicts, check system compatibility, and export to any format.",
      "maintainer": "UDR Team <team@udr.example.com>",
      "artifactName": "${productName}-${version}-${os}-${arch}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0",
    "electron-updater": "^6.0.0"
  }
}

// Generated by Universal Dependency Resolver
// Date: {{ timestamp }}
// Do not edit manually - this file is auto-generated

plugins {
    id("java")
    id("application")
{% if options.use_kotlin %}
    kotlin("jvm") version "1.9.0"
{% endif %}
{% if options.use_spring %}
    id("org.springframework.boot") version "3.1.0"
{% endif %}
}

group = "{{ options.group_id|default('com.example') }}"
version = "{{ options.project_version|default('1.0.0') }}"

java {
    sourceCompatibility = JavaVersion.VERSION_{{ options.java_version|default('17') }}
    targetCompatibility = JavaVersion.VERSION_{{ options.java_version|default('17') }}
}

repositories {
    mavenCentral()
{% if options.repositories %}
{% for repo in options.repositories %}
    maven { url = uri("{{ repo }}") }
{% endfor %}
{% endif %}
}

dependencies {
{% for pkg in ecosystems.get('maven', []) %}
{% set scope = pkg.extras.scope|default('implementation') %}
{% if ':' in pkg.name %}
{% set group_id, artifact_id = pkg.name.split(':', 1) %}
{% else %}
{% set group_id, artifact_id = 'unknown', pkg.name %}
{% endif %}
{% set dep_string = '"' + group_id + ':' + artifact_id + ':' + pkg.version + '"' %}
{% if scope == 'test' %}
    testImplementation({{ dep_string }})
{% elif scope == 'runtime' %}
    runtimeOnly({{ dep_string }})
{% else %}
    implementation({{ dep_string }})
{% endif %}
{% endfor %}
{% if options.include_testing != false %}
    testImplementation("org.junit.jupiter:junit-jupiter:5.9.3")
{% endif %}
}

application {
    mainClass.set("{{ options.main_class|default('com.example.Main') }}")
}

tasks.test {
    useJUnitPlatform()
}
{% if options.custom_tasks %}
{% for task_name, task_config in options.custom_tasks.items() %}

tasks.register("{{ task_name }}") {
    {{ task_config }}
}
{% endfor %}
{% endif %}
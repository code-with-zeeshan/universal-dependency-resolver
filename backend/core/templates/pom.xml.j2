<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>{{ options.group_id|default('com.example') }}</groupId>
    <artifactId>{{ options.artifact_id|default('my-app') }}</artifactId>
    <version>{{ options.project_version|default('1.0.0') }}</version>
    <packaging>{{ options.packaging|default('jar') }}</packaging>

    <name>{{ options.project_name|default('My Application') }}</name>
    <description>{{ options.description|default('Generated by Universal Dependency Resolver') }}</description>

    <properties>
        <maven.compiler.source>{{ options.java_version|default('17') }}</maven.compiler.source>
        <maven.compiler.target>{{ options.java_version|default('17') }}</maven.compiler.target>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>
{% for pkg in ecosystems.get('maven', []) %}
{% set version_key = pkg.name.split(':')[1].replace('-', '.') + '.version' if ':' in pkg.name else pkg.name.replace('-', '.') + '.version' %}
        <{{ version_key }}>{{ pkg.version }}</{{ version_key }}>
{% endfor %}
    </properties>

    <dependencies>
{% for pkg in ecosystems.get('maven', []) %}
        <dependency>
{% if ':' in pkg.name %}
{% set group_id, artifact_id = pkg.name.split(':', 1) %}
{% else %}
{% set group_id, artifact_id = 'unknown', pkg.name %}
{% endif %}
            <groupId>{{ group_id }}</groupId>
            <artifactId>{{ artifact_id }}</artifactId>
            <version>${{ '{' }}{{ artifact_id.replace('-', '.') }}.version}</version>
{% set scope = pkg.extras.scope|default('compile') %}
{% if scope != 'compile' %}
            <scope>{{ scope }}</scope>
{% endif %}
        </dependency>
{% endfor %}
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.11.0</version>
                <configuration>
                    <source>{{ options.java_version|default('17') }}</source>
                    <target>{{ options.java_version|default('17') }}</target>
                </configuration>
            </plugin>
{% if options.include_surefire != false %}
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>3.1.2</version>
            </plugin>
{% endif %}
{% if options.include_jar_plugin != false %}
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jar-plugin</artifactId>
                <version>3.3.0</version>
                <configuration>
                    <archive>
                        <manifest>
                            <mainClass>{{ options.main_class|default('com.example.Main') }}</mainClass>
                        </manifest>
                    </archive>
                </configuration>
            </plugin>
{% endif %}
        </plugins>
    </build>
</project>
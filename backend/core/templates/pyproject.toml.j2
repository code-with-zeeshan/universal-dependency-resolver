[tool.poetry]
name = "{{ options.project_name|default('my-project') }}"
version = "{{ options.project_version|default('0.1.0') }}"
description = "{{ options.description|default('Generated by Universal Dependency Resolver') }}"
authors = ["{{ options.author|default('Your Name <you@example.com>') }}"]
readme = "{{ options.readme|default('README.md') }}"
license = "{{ options.license|default('MIT') }}"
homepage = "{{ options.homepage|default('') }}"
repository = "{{ options.repository|default('') }}"
keywords = {{ options.keywords|default([]) }}
classifiers = {{ options.classifiers|default([]) }}

[tool.poetry.dependencies]
{% if system_info.runtime_versions.python.version %}
{% set py_major, py_minor = system_info.runtime_versions.python.version.split('.')[:2] %}
python = "^{{ py_major }}.{{ py_minor }}"
{% endif %}
{% for pkg in ecosystems.get('pypi', []) %}
{% if not pkg.extras.dev %}
{% if options.pin_versions != false %}
{{ pkg.name }} = "{{ pkg.version }}"
{% else %}
{{ pkg.name }} = "^{{ pkg.version }}"
{% endif %}
{% endif %}
{% endfor %}

[tool.poetry.group.dev.dependencies]
{% for pkg in ecosystems.get('pypi', []) %}
{% if pkg.extras.dev %}
{% if options.pin_versions != false %}
{{ pkg.name }} = "{{ pkg.version }}"
{% else %}
{{ pkg.name }} = "^{{ pkg.version }}"
{% endif %}
{% endif %}
{% endfor %}

[build-system]
requires = ["poetry-core"]
build-backend = "poetry.core.masonry.api"
{% if options.scripts %}

[tool.poetry.scripts]
{% for name, script in options.scripts.items() %}
{{ name }} = "{{ script }}"
{% endfor %}
{% endif %}

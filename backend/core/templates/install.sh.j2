#!/usr/bin/env bash
# Generated by Universal Dependency Resolver
# Date: {{ timestamp }}
# Do not edit manually - this file is auto-generated

set -euo pipefail

# Color output
RED="\033[0;31m"
GREEN="\033[0;32m"
YELLOW="\033[0;33m"
NC="\033[0m"

# Logging functions
log_info() { echo -e "${GREEN}[INFO]${NC} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
log_error() { echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

log_info "Starting dependency installation..."

# Detect OS
if [[ "$OSTYPE" == "linux-gnu"* ]]; then
    OS="linux"
elif [[ "$OSTYPE" == "darwin"* ]]; then
    OS="macos"
else
    log_error "Unsupported OS: $OSTYPE"
fi

# Check required tools
check_command() {
    if ! command -v "$1" &> /dev/null; then
        log_error "$1 is required but not installed"
    fi
}

{% set pypi_pkgs = ecosystems.get('pypi', []) | sort(attribute='name') %}
{% set npm_pkgs = ecosystems.get('npm', []) | sort(attribute='name') %}
{% set gem_pkgs = ecosystems.get('rubygems', []) | sort(attribute='name') %}
{% set go_pkgs = ecosystems.get('gomodules', []) | sort(attribute='name') %}
{% set php_pkgs = ecosystems.get('packagist', []) | sort(attribute='name') %}
{% set nuget_pkgs = ecosystems.get('nuget', []) | sort(attribute='name') %}
{% set brew_pkgs = ecosystems.get('homebrew', []) | sort(attribute='name') %}
{% set apk_pkgs = ecosystems.get('apk', []) | sort(attribute='name') %}
{% set apt_pkgs = ecosystems.get('apt', []) | sort(attribute='name') %}

{% if pypi_pkgs %}
# Python packages
check_command python3
check_command pip3

log_info "Installing Python packages..."

# Upgrade pip
python3 -m pip install --upgrade pip

# Install packages
{% for pkg in pypi_pkgs %}
pip3 install "{{ pkg.name }}=={{ pkg.version }}"
{% endfor %}

{% endif %}
{% if npm_pkgs %}
# Node.js packages
check_command node
check_command npm

log_info "Installing Node.js packages..."

{% for pkg in npm_pkgs %}
npm install -g "{{ pkg.name }}@{{ pkg.version }}"
{% endfor %}

{% endif %}
{% if gem_pkgs %}
# Ruby gems
check_command ruby
check_command gem

log_info "Installing Ruby gems..."

{% for pkg in gem_pkgs %}
gem install "{{ pkg.name }}" -v "{{ pkg.version }}"
{% endfor %}

{% endif %}
{% if go_pkgs %}
# Go modules
check_command go

log_info "Installing Go modules..."

{% for pkg in go_pkgs %}
go install "{{ pkg.name }}@{{ pkg.version }}"
{% endfor %}

{% endif %}
{% if php_pkgs %}
# PHP packages
check_command php
check_command composer

log_info "Installing PHP packages..."

{% for pkg in php_pkgs %}
composer global require "{{ pkg.name }}:{{ pkg.version }}"
{% endfor %}

{% endif %}
{% if nuget_pkgs %}
# .NET packages
check_command dotnet

log_info "Installing .NET packages..."

{% for pkg in nuget_pkgs %}
dotnet tool install --global "{{ pkg.name }}" --version "{{ pkg.version }}"
{% endfor %}

{% endif %}
{% if brew_pkgs %}
# Homebrew packages (macOS only)
if [[ "$OS" == "macos" ]]; then
    check_command brew
    log_info "Installing Homebrew packages..."
{% for pkg in brew_pkgs %}
{% if pkg.version %}
    brew install "{{ pkg.name }}@{{ pkg.version }}"
{% else %}
    brew install "{{ pkg.name }}"
{% endif %}
{% endfor %}
fi

{% endif %}
{% if apk_pkgs %}
# Alpine packages
if command -v apk &> /dev/null; then
    log_info "Installing Alpine packages..."
    apk update
{% for pkg in apk_pkgs %}
{% if pkg.version %}
    apk add "{{ pkg.name }}={{ pkg.version }}"
{% else %}
    apk add "{{ pkg.name }}"
{% endif %}
{% endfor %}
fi

{% endif %}
{% if apt_pkgs %}
# System packages (Linux only)
if [[ "$OS" == "linux" ]]; then
    log_info "Installing system packages..."
    if [[ $EUID -ne 0 ]]; then
        SUDO="sudo"
    else
        SUDO=""
    fi
    $SUDO apt-get update
{% for pkg in apt_pkgs %}
    $SUDO apt-get install -y {{ pkg.name }}
{% endfor %}
fi

{% endif %}
{% if options.verify_installation != false %}
# Verify installation
log_info "Verifying installation..."

{% if pypi_pkgs %}
python3 -c "import pkg_resources; print(\"Python packages verified\")"
{% endif %}

{% endif %}
log_info "Installation completed successfully!"

# Display summary
echo ""
echo "Installed packages:"
echo "  Python: {{ pypi_pkgs | length }} packages"
echo "  Node.js: {{ npm_pkgs | length }} packages"
echo "  Ruby: {{ gem_pkgs | length }} packages"
echo "  Go: {{ go_pkgs | length }} packages"
echo "  PHP: {{ php_pkgs | length }} packages"
echo "  .NET: {{ nuget_pkgs | length }} packages"
echo "  System (APT): {{ apt_pkgs | length }} packages"
echo "  System (APK): {{ apk_pkgs | length }} packages"
echo "  macOS (Homebrew): {{ brew_pkgs | length }} packages"

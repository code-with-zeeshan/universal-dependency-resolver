[package]
name = "{{ options.project_name|default('my-project') }}"
version = "{{ options.project_version|default('0.1.0') }}"
edition = "2021"
authors = ["{{ options.author|default('Your Name <you@example.com>') }}"]
description = "{{ options.description|default('Generated by Universal Dependency Resolver') }}"
license = "{{ options.license|default('MIT') }}"
repository = "{{ options.repository|default('') }}"
keywords = {{ options.keywords|default([]) }}
categories = {{ options.categories|default([]) }}

[dependencies]
{% for pkg in ecosystems.get('crates', []) %}
{% if pkg.extras.features %}
{{ pkg.name }} = { version = "{{ pkg.version }}", features = {{ pkg.extras.features|tojson }} }
{% else %}
{{ pkg.name }} = "{{ pkg.version }}"
{% endif %}
{% endfor %}

[dev-dependencies]

[build-dependencies]

[profile.release]
lto = true
codegen-units = 1
opt-level = 3
{% if options.workspace %}

[workspace]
members = {{ options.workspace|tojson }}
{% endif %}
{% if options.targets %}
{% if options.targets.bin %}

[[bin]]
{% for bin in options.targets.bin %}
name = "{{ bin.name }}"
path = "{{ bin.path }}"
{% endfor %}
{% endif %}
{% if options.targets.lib %}

[lib]
name = "{{ options.targets.lib.name }}"
path = "{{ options.targets.lib.path }}"
{% endif %}
{% endif %}
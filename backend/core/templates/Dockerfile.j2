# Generated by Universal Dependency Resolver
# Date: {{ timestamp }}
# Do not edit manually - this file is auto-generated

{% if options.multi_stage != false %}
# Builder stage
FROM {{ base_image }} AS builder

WORKDIR /build

# Install build dependencies
{% set has_python = ecosystems.get('pypi', []) | length > 0 %}
{% set has_node = ecosystems.get('npm', []) | length > 0 %}
{% set has_cpp = ecosystems.get('conan', []) | length > 0 or ecosystems.get('vcpkg', []) | length > 0 %}
{% set cmds = ['apt-get update'] %}
{% if has_python %}{% set _ = cmds.append('apt-get install -y python3-dev python3-pip build-essential') %}{% endif %}
{% if has_node %}{% set _ = cmds.append('apt-get install -y nodejs npm') %}{% endif %}
{% if has_cpp %}{% set _ = cmds.append('apt-get install -y cmake g++ git') %}{% endif %}
{% set _ = cmds.append('rm -rf /var/lib/apt/lists/*') %}
RUN {{ cmds | join(' && \\\n    ') }}

# Copy dependency files
{% if has_python %}
COPY requirements.txt* pyproject.toml* setup.py* ./
{% endif %}
{% if has_node %}
COPY package*.json ./
{% endif %}

{% if has_python %}
# Install Python packages
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
{% endif %}
{% if has_node %}
# Install Node.js packages
COPY package*.json .
RUN npm ci --only=production
{% endif %}

# Runtime stage
FROM {{ base_image }}

WORKDIR /app

# Install runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    libpython3-stdlib{% for dep in runtime_deps %}
    {{ dep }}{% endfor %}
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder
COPY --from=builder /usr/local /usr/local

{% if options.health_check != false %}
# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD {{ options.health_check_cmd|default('curl -f http://localhost:8080/health || exit 1') }}
{% endif %}

{% if options.non_root_user != false %}
# Create non-root user
RUN useradd -m -u 1000 appuser && chown -R appuser:appuser /app
USER appuser
{% endif %}

# Labels
{% set labels = {'maintainer': options.maintainer|default(''), 'version': options.version|default('1.0.0'), 'description': options.description|default('Generated by Universal Dependency Resolver'), 'build-date': timestamp} %}
{% for key, value in labels.items() %}
{% if value %}
LABEL {{ key }}="{{ value }}"
{% endif %}
{% endfor %}

# Entrypoint
{% if options.entrypoint %}
ENTRYPOINT {{ options.entrypoint|tojson }}
{% endif %}
{% if options.cmd %}
CMD {{ options.cmd|tojson }}
{% elif not options.entrypoint %}
CMD ["/bin/bash"]
{% endif %}

{% else %}
# Single-stage build
FROM {{ base_image }}

WORKDIR /app

{# Install system packages #}
{% set apt_packages = ecosystems.get('apt', []) %}
{% if apt_packages %}
# Install system packages
{% set apt_cmds = ['apt-get update'] %}
{% for pkg in apt_packages %}
{% set _ = apt_cmds.append('apt-get install -y ' + pkg.name) %}
{% endfor %}
{% set _ = apt_cmds.append('rm -rf /var/lib/apt/lists/*') %}
RUN {{ apt_cmds | join(' && \\\n    ') }}
{% endif %}

{# Install Python packages #}
{% set python_packages = ecosystems.get('pypi', []) %}
{% if python_packages %}
# Install Python packages
{% set pkg_list = [] %}
{% for pkg in python_packages %}
{% set _ = pkg_list.append(pkg.name + '==' + pkg.version) %}
{% endfor %}
RUN pip install --no-cache-dir {{ pkg_list | join(' ') }}
{% endif %}

{# Install Node.js packages #}
{% set npm_packages = ecosystems.get('npm', []) %}
{% if npm_packages %}
# Install Node.js packages
{% for pkg in npm_packages %}
RUN npm install -g {{ pkg.name }}@{{ pkg.version }}
{% endfor %}
{% endif %}

{% if options.health_check != false %}
# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=40s --retries=3 \
  CMD {{ options.health_check_cmd|default('curl -f http://localhost:8080/health || exit 1') }}
{% endif %}

# Entrypoint
{% if options.entrypoint %}
ENTRYPOINT {{ options.entrypoint|tojson }}
{% endif %}
{% if options.cmd %}
CMD {{ options.cmd|tojson }}
{% elif not options.entrypoint %}
CMD ["/bin/bash"]
{% endif %}
{% endif %}

@echo off
REM Generated by Universal Dependency Resolver
REM Date: {{ timestamp }}
REM Do not edit manually - this file is auto-generated

setlocal enabledelayedexpansion

echo ================================
echo Dependency Installation Script
echo ================================
echo.
{% if options.require_admin %}
REM Check for admin rights
net session >nul 2>&1
if %errorLevel% neq 0 (
    echo This script requires administrator privileges.
    echo Please run as administrator.
    pause
    exit /b 1
)

{% endif %}
{% set pypi_pkgs = ecosystems.get('pypi', []) | sort(attribute='name') %}
{% set npm_pkgs = ecosystems.get('npm', []) | sort(attribute='name') %}
{% set choco_pkgs = ecosystems.get('chocolatey', []) | sort(attribute='name') %}
{% if pypi_pkgs %}
REM Python packages
echo Checking Python installation...
where python >nul 2>&1
if %errorLevel% neq 0 (
    echo Python is not installed or not in PATH
    echo Please install Python from https://python.org
    pause
    exit /b 1
)

echo Installing Python packages...
python -m pip install --upgrade pip

{% for pkg in pypi_pkgs %}
python -m pip install "{{ pkg.name }}=={{ pkg.version }}"
if %errorLevel% neq 0 ( echo Failed to install {{ pkg.name }} && exit /b 1 )
{% endfor %}

{% endif %}
{% if npm_pkgs %}
REM Node.js packages
echo Checking Node.js installation...
where npm >nul 2>&1
if %errorLevel% neq 0 (
    echo npm is not installed or not in PATH
    echo Please install Node.js from https://nodejs.org
    pause
    exit /b 1
)

echo Installing Node.js packages...

{% for pkg in npm_pkgs %}
npm install -g "{{ pkg.name }}@{{ pkg.version }}"
if %errorLevel% neq 0 ( echo Failed to install {{ pkg.name }} && exit /b 1 )
{% endfor %}

{% endif %}
{% if options.use_chocolatey and choco_pkgs %}
REM Chocolatey packages
echo Checking Chocolatey installation...
where choco >nul 2>&1
if %errorLevel% neq 0 (
    echo Installing Chocolatey...
    @"%SystemRoot%\System32\WindowsPowerShell\v1.0\powershell.exe" -NoProfile -InputFormat None -ExecutionPolicy Bypass -Command "[System.Net.ServicePointManager]::SecurityProtocol = 3072; iex ((New-Object System.Net.WebClient).DownloadString('https://chocolatey.org/install.ps1'))"
)

echo Installing Chocolatey packages...

{% for pkg in choco_pkgs %}
{% if pkg.version %}
choco install {{ pkg.name }} --version {{ pkg.version }} -y
{% else %}
choco install {{ pkg.name }} -y
{% endif %}
{% endfor %}

{% endif %}
echo.
echo ================================
echo Installation completed!
echo ================================

echo.
echo Installed packages:
echo   Python: {{ pypi_pkgs | length }} packages
echo   Node.js: {{ npm_pkgs | length }} packages

pause
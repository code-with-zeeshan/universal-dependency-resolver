# Universal Dependency Resolver — Configuration
# Copy to .env and customize.

# Authentication (default: disabled)
ENABLE_AUTH=false
SECRET_KEY=your-secret-key-here-change-in-production

# Database (default: SQLite)
DATABASE_URL=sqlite:///./udr.db

# Cache
ENABLE_CACHE=true
CACHE_TTL=3600
CACHE_TTL_SHORT=300

# Logging
LOG_LEVEL=INFO
ENABLE_REQUEST_LOGGING=false

# HTTP client
REQUEST_TIMEOUT=30
MAX_RETRIES=3

# Rate limits (requests per minute per ecosystem)
PYPI_RATE_LIMIT=600
NPM_RATE_LIMIT=600
CONDA_RATE_LIMIT=300
MAVEN_RATE_LIMIT=300
CRATES_RATE_LIMIT=300
GITHUB_RATE_LIMIT=60

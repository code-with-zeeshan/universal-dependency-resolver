# =============================================================================
# Universal Dependency Resolver - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/depresolver
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# API Configuration
# =============================================================================
API_VERSION=v1
API_TITLE=Universal Dependency Resolver API
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# Authentication & Security
# =============================================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENABLE_API_KEY_AUTH=false
API_KEY_HEADER=X-API-Key

# =============================================================================
# Rate Limiting
# =============================================================================
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_HOUR=1000
API_RATE_LIMIT_BURST=10
RESOLVE_RATE_LIMIT=10/minute
EXPORT_RATE_LIMIT=20/minute
BENCHMARK_RATE_LIMIT=5/minute
HEALTH_RATE_LIMIT=30/minute

# =============================================================================
# Package Registry URLs (defaults point to official registries)
# =============================================================================
# PyPI
PYPI_URL=https://pypi.org
PYPI_SIMPLE_URL=https://pypi.org/simple
PYPI_JSON_URL=https://pypi.org/pypi

# Conda
CONDA_URL=https://repo.anaconda.com/pkgs/main
CONDA_FORGE_URL=https://conda.anaconda.org/conda-forge

# NPM
NPM_URL=https://registry.npmjs.org
NPM_SEARCH_URL=https://registry.npmjs.org/-/v1/search

# Maven
MAVEN_CENTRAL_URL=https://repo1.maven.org/maven2
MAVEN_SEARCH_URL=https://search.maven.org/solrsearch/select

# Crates.io
CRATES_URL=https://crates.io/api/v1

# RubyGems
RUBYGEMS_URL=https://rubygems.org
RUBYGEMS_API_URL=https://rubygems.org/api/v1

# NuGet
NUGET_URL=https://www.nuget.org
NUGET_API_URL=https://api.nuget.org/v3/index.json

# Packagist
PACKAGIST_URL=https://packagist.org
PACKAGIST_API_URL=https://repo.packagist.org/p2

# Homebrew
HOMEBREW_URL=https://brew.sh
HOMEBREW_API_URL=https://formulae.brew.sh/api

# Go Modules
GOMODULES_PROXY_URL=https://proxy.golang.org
GOMODULES_SUM_DB_URL=https://sum.golang.org

# APT
APT_REPOSITORIES=http://deb.debian.org/debian,http://archive.ubuntu.com/ubuntu
APT_DISTRIBUTIONS=stable,testing,unstable

# APK
APK_REPOSITORIES=https://dl-cdn.alpinelinux.org/alpine/v3.18/main,https://dl-cdn.alpinelinux.org/alpine/v3.18/community
APK_BRANCHES=v3.18,v3.17,edge

# CocoaPods
COCOAPODS_API_URL=https://trunk.cocoapods.org/api/v1
COCOAPODS_SPECS_URL=https://cdn.cocoapods.org

# =============================================================================
# Cache Configuration
# =============================================================================
CACHE_TTL=3600
CACHE_TTL_SHORT=300
CACHE_TTL_LONG=86400
CACHE_MAX_SIZE=1000
CACHE_EVICTION_POLICY=LRU
PACKAGE_INFO_CACHE_TTL=3600
VERSION_LIST_CACHE_TTL=300
SEARCH_CACHE_TTL=300
DEPENDENCY_CACHE_TTL=3600
COMPATIBILITY_CACHE_TTL=86400

# =============================================================================
# HTTP Client Configuration
# =============================================================================
REQUEST_TIMEOUT=30
CONNECT_TIMEOUT=10
MAX_CONNECTIONS=100
HTTP_CLIENT_MAX_REDIRECTS=5

# =============================================================================
# Monitoring & Observability
# =============================================================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
# Protocol: http/protobuf (default) or grpc
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Examples:
#   Self-hosted Jaeger:     http://jaeger:4318/v1/traces
#   Self-hosted Tempo:      http://tempo:4318/v1/traces
#   Grafana Cloud:          https://otlp-gateway-prod-us-central-0.grafana.net/otlp
#   Datadog:                https://trace.agent.datadoghq.com/api/v0.2/traces
#   Honeycomb:              https://api.honeycomb.io/v1/traces
#   New Relic:              https://otlp.nr-data.net:4318/v1/traces
#   Lightstep:              https://ingest.lightstep.com:443/api/v0.2/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
# Comma-separated: Key1=Value1,Key2=Value2
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
OTEL_EXPORTER_OTLP_TIMEOUT=10
# Sampler: always_on, always_off, traceidratio, parentbased_traceidratio, parentbased_always_on, parentbased_always_off
OTEL_SAMPLER_TYPE=parentbased_traceidratio
OTEL_SAMPLER_ARG=0.1
OTEL_SERVICE_NAME=universal-dependency-resolver
OTEL_SERVICE_VERSION=1.0.0
# Extra resource attributes: key1=val1,key2=val2
OTEL_RESOURCE_ATTRIBUTES=

# =============================================================================
# File Upload Configuration
# =============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_EXTENSIONS=.txt,.json,.yml,.yaml,.toml,.lock

# =============================================================================
# Celery / Background Tasks
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379
CELERY_TASK_TIME_LIMIT=300

# =============================================================================
# Email Configuration
# =============================================================================
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@depresolver.com

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_CACHE=true
ENABLE_ASYNC=true
ENABLE_METRICS=true
ENABLE_AUTH=false
ENABLE_WEBHOOKS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_BACKGROUND_TASKS=true
ENABLE_FILE_UPLOADS=true
ENABLE_DEPENDENCY_GRAPH=true

# =============================================================================
# Performance
# =============================================================================
MAX_PARALLEL_REQUESTS=10
MAX_PARALLEL_DOWNLOADS=5
THREAD_POOL_SIZE=20
SLOW_REQUEST_THRESHOLD=5.0

# =============================================================================
# System Scanner
# =============================================================================
SYSTEM_SCAN_TIMEOUT=60
ENABLE_GPU_DETECTION=true
ENABLE_CONTAINER_DETECTION=true
ENABLE_PACKAGE_SCANNING=true

# =============================================================================
# Security Scanning
# =============================================================================
ENABLE_SECURITY_SCANNING=true
VULNERABILITY_CHECK_ENABLED=true
LICENSE_CHECK_ENABLED=true
ALLOWED_LICENSES=MIT,Apache-2.0,BSD-3-Clause,BSD-2-Clause,ISC,GPL-3.0
OSV_API_URL=https://api.osv.dev/v1/query

# =============================================================================
# WebSocket / Real-time
# =============================================================================
WEBSOCKET_ENABLED=true
SOCKETIO_ENABLED=true
REALTIME_MAX_CONNECTIONS=100

# =============================================================================
# Database Migration
# =============================================================================
AUTO_MIGRATE_ON_STARTUP=false

# =============================================================================
# Frontend
# =============================================================================
VUE_APP_API_URL=http://localhost:8000

# =============================================================================
# API Keys (Optional)
# =============================================================================
GITHUB_TOKEN=
NPM_TOKEN=

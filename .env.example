# =============================================================================
# Universal Dependency Resolver - Environment Configuration
# =============================================================================
# Copy this file to .env and customize for your environment.

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://user:password@localhost:5432/depresolver
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=50

# =============================================================================
# API Configuration
# =============================================================================
API_VERSION=v1
API_TITLE=Universal Dependency Resolver API
API_DESCRIPTION=A comprehensive API for resolving dependencies across multiple package ecosystems
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000
ALLOW_CREDENTIALS=true
ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOW_HEADERS=*
ENVIRONMENT=development
ENV=development
DEBUG=false
TESTING=false
LOG_LEVEL=INFO
SECRET_KEY=your-secret-key-here-change-in-production

# =============================================================================
# Authentication & Security
# =============================================================================
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ENABLE_API_KEY_AUTH=false
API_KEY_HEADER=X-API-Key
SENTRY_ENVIRONMENT=development

# =============================================================================
# Rate Limiting
# =============================================================================
API_RATE_LIMIT_ENABLED=true
API_RATE_LIMIT_PER_MINUTE=60
API_RATE_LIMIT_PER_HOUR=1000
API_RATE_LIMIT_BURST=10
RESOLVE_RATE_LIMIT=10/minute
EXPORT_RATE_LIMIT=20/minute
BENCHMARK_RATE_LIMIT=5/minute
HEALTH_RATE_LIMIT=30/minute

# =============================================================================
# Package Registry URLs (defaults point to official registries)
# =============================================================================
# PyPI
PYPI_URL=https://pypi.org
PYPI_SIMPLE_URL=https://pypi.org/simple
PYPI_JSON_URL=https://pypi.org/pypi
PYPI_XMLRPC_URL=https://pypi.org/pypi
PYPI_MIRROR_URLS=
PYPI_RATE_LIMIT=600
PYPI_USER_AGENT=UniversalDependencyResolver/1.0 (PyPI Client)

# Conda
CONDA_URL=https://repo.anaconda.com/pkgs/main
CONDA_FORGE_URL=https://conda.anaconda.org/conda-forge
CONDA_DEFAULTS_URL=https://repo.anaconda.com/pkgs/main
CONDA_PYTORCH_URL=https://conda.anaconda.org/pytorch
CONDA_NVIDIA_URL=https://conda.anaconda.org/nvidia
CONDA_BIOCONDA_URL=https://conda.anaconda.org/bioconda
CONDA_R_URL=https://conda.anaconda.org/r
CONDA_RATE_LIMIT=300

# NPM
NPM_URL=https://registry.npmjs.org
NPM_SEARCH_URL=https://registry.npmjs.org/-/v1/search
NPM_DOWNLOADS_API=https://api.npmjs.org/downloads
NPM_MIRROR_URLS=
NPM_RATE_LIMIT=600
NPM_USER_AGENT=UniversalDependencyResolver/1.0 (NPM Client)

# Maven
MAVEN_CENTRAL_URL=https://repo1.maven.org/maven2
MAVEN_SEARCH_URL=https://search.maven.org/solrsearch/select
MAVEN_ARTIFACT_URL=https://search.maven.org/artifact
MAVEN_ADDITIONAL_REPOS=
MAVEN_RATE_LIMIT=300

# Crates.io
CRATES_URL=https://crates.io/api/v1
CRATES_INDEX_URL=https://github.com/rust-lang/crates.io-index
CRATES_DL_URL=https://crates.io/api/v1/crates
CRATES_RATE_LIMIT=300

# RubyGems
RUBYGEMS_URL=https://rubygems.org
RUBYGEMS_API_URL=https://rubygems.org/api/v1

# NuGet
NUGET_URL=https://www.nuget.org
NUGET_API_URL=https://api.nuget.org/v3/index.json

# Packagist
PACKAGIST_URL=https://packagist.org
PACKAGIST_API_URL=https://repo.packagist.org/p2

# Homebrew
HOMEBREW_URL=https://brew.sh
HOMEBREW_API_URL=https://formulae.brew.sh/api

# Go Modules
GOMODULES_PROXY_URL=https://proxy.golang.org
GOMODULES_SUM_DB_URL=https://sum.golang.org

# APT
APT_REPOSITORIES=http://deb.debian.org/debian,http://archive.ubuntu.com/ubuntu
APT_DISTRIBUTIONS=stable,testing,unstable

# APK
APK_REPOSITORIES=https://dl-cdn.alpinelinux.org/alpine/v3.18/main,https://dl-cdn.alpinelinux.org/alpine/v3.18/community
APK_BRANCHES=v3.18,v3.17,edge

# CocoaPods
COCOAPODS_API_URL=https://trunk.cocoapods.org/api/v1
COCOAPODS_SPECS_URL=https://cdn.cocoapods.org

# =============================================================================
# Cache Configuration
# =============================================================================
CACHE_TTL=3600
CACHE_TTL_SHORT=300
CACHE_TTL_LONG=86400
CACHE_MAX_SIZE=1000
CACHE_EVICTION_POLICY=LRU
PACKAGE_INFO_CACHE_TTL=3600
VERSION_LIST_CACHE_TTL=300
SEARCH_CACHE_TTL=300
DEPENDENCY_CACHE_TTL=3600
COMPATIBILITY_CACHE_TTL=86400
REDIS_DECODE_RESPONSES=true

# =============================================================================
# HTTP Client Configuration
# =============================================================================
REQUEST_TIMEOUT=30
CONNECT_TIMEOUT=10
READ_TIMEOUT=30
MAX_CONNECTIONS=100
MAX_KEEPALIVE_CONNECTIONS=20
HTTP_CLIENT_TIMEOUT=30
HTTP_CLIENT_MAX_REDIRECTS=5
HTTP_CLIENT_RETRY_DELAY=5
HTTP_CLIENT_RETRY_COUNT=3
DEFAULT_USER_AGENT=UniversalDependencyResolver/1.0
DOC_USER_AGENT=Mozilla/5.0 (compatible; DocScraper/1.0)

# Retry & Circuit Breaker
MAX_RETRIES=3
RETRY_BACKOFF_FACTOR=2.0
RETRY_MAX_DELAY=60.0
RATE_LIMIT_DELAY=0.1
RATE_LIMIT_ENABLED=true
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_OPEN_TIME=30
MAX_REQUEST_SIZE=10485760
MAX_RESPONSE_SIZE=10485760
GITHUB_RATE_LIMIT=60

# =============================================================================
# Monitoring & Observability
# =============================================================================
PROMETHEUS_ENABLED=false
PROMETHEUS_PORT=9090
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
OTEL_ENABLED=false
# Protocol: http/protobuf (default) or grpc
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Examples:
#   Self-hosted Jaeger:     http://jaeger:4318/v1/traces
#   Self-hosted Tempo:      http://tempo:4318/v1/traces
#   Grafana Cloud:          https://otlp-gateway-prod-us-central-0.grafana.net/otlp
#   Datadog:                https://trace.agent.datadoghq.com/api/v0.2/traces
#   Honeycomb:              https://api.honeycomb.io/v1/traces
#   New Relic:              https://otlp.nr-data.net:4318/v1/traces
#   Lightstep:              https://ingest.lightstep.com:443/api/v0.2/traces
OTEL_EXPORTER_OTLP_ENDPOINT=
# Comma-separated: Key1=Value1,Key2=Value2
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_COMPRESSION=gzip
OTEL_EXPORTER_OTLP_TIMEOUT=10
# Sampler: always_on, always_off, traceidratio, parentbased_traceidratio, parentbased_always_on, parentbased_always_off
OTEL_SAMPLER_TYPE=parentbased_traceidratio
OTEL_SAMPLER_ARG=0.1
OTEL_SERVICE_NAME=universal-dependency-resolver
OTEL_SERVICE_VERSION=1.0.0
# Extra resource attributes: key1=val1,key2=val2
OTEL_RESOURCE_ATTRIBUTES=

# =============================================================================
# File Upload Configuration
# =============================================================================
MAX_UPLOAD_SIZE=10485760
ALLOWED_UPLOAD_EXTENSIONS=.txt,.json,.yml,.yaml,.toml,.lock
UPLOAD_TEMP_DIR=/tmp/uploads

# =============================================================================
# Celery / Background Tasks
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379
CELERY_RESULT_BACKEND=redis://localhost:6379
CELERY_TASK_TIME_LIMIT=300
CELERY_TASK_SOFT_TIME_LIMIT=240
CELERY_WORKER_CONCURRENCY=4

# =============================================================================
# Email Configuration
# =============================================================================
EMAIL_ENABLED=false
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
EMAIL_FROM=noreply@depresolver.com

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_CACHE=true
ENABLE_ASYNC=true
ENABLE_METRICS=true
# WARNING: App refuses to start in production mode with ENABLE_AUTH=false
ENABLE_AUTH=false
ENABLE_WEBHOOKS=false
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_BACKGROUND_TASKS=true
ENABLE_FILE_UPLOADS=true
ENABLE_DEPENDENCY_GRAPH=true
ENABLE_PROFILING=false
ENABLE_DEBUG_MODE=false
ENABLE_EXPERIMENTAL_FEATURES=false
ENABLE_AUTO_UPDATE=false
ENABLE_TELEMETRY=false
ENABLE_API_VERSIONING=true
ENABLE_RESPONSE_COMPRESSION=true
ENABLE_CSRF=true
ENABLED_ECOSYSTEMS=pypi,conda,npm,crates,maven,apt
ENABLED_EXPORT_FORMATS=requirements.txt,package.json,environment.yml,pyproject.toml,Dockerfile,docker-compose.yml,install.sh,install.bat,CMakeLists.txt,Cargo.toml,build.gradle,pom.xml

# =============================================================================
# Performance
# =============================================================================
MAX_PARALLEL_REQUESTS=10
MAX_PARALLEL_DOWNLOADS=5
THREAD_POOL_SIZE=20
SLOW_REQUEST_THRESHOLD=5.0

# =============================================================================
# Logging Configuration
# =============================================================================
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
LOG_DATE_FORMAT=%Y-%m-%d %H:%M:%S
LOG_FILE=
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
ENABLE_REQUEST_LOGGING=false
ENABLE_CACHE_LOGGING=false
ENABLE_PERFORMANCE_LOGGING=true

# =============================================================================
# Default Runtime Versions
# =============================================================================
DEFAULT_PYTHON_VERSION=3.9
DEFAULT_NODE_VERSION=18
DEFAULT_JAVA_VERSION=17
DEFAULT_RUST_VERSION=stable

# =============================================================================
# Pagination
# =============================================================================
PAGINATION_DEFAULT_LIMIT=20
PAGINATION_MAX_LIMIT=100

# =============================================================================
# Webhook Configuration
# =============================================================================
WEBHOOK_ENABLED=false
WEBHOOK_TIMEOUT=10
WEBHOOK_MAX_RETRIES=3

# =============================================================================
# Health Check Configuration
# =============================================================================
HEALTH_CHECK_INCLUDE_DETAILS=true
HEALTH_CHECK_CACHE_TTL=10

# =============================================================================
# Documentation Scraper
# =============================================================================
DOC_SCRAPER_ENABLED=true
DOC_SCRAPER_TIMEOUT=30
DOC_SCRAPER_MAX_PAGES=10
DOC_SCRAPER_FOLLOW_REDIRECTS=true
INCLUDE_ADDITIONAL_DOC_URLS=false
TENSORFLOW_DOCS_URL=https://www.tensorflow.org/install
PYTORCH_DOCS_URL=https://pytorch.org/get-started/locally/
TENSORRT_DOCS_URL=https://docs.nvidia.com/deeplearning/tensorrt/install-guide/index.html
OPENCV_DOCS_URL=https://docs.opencv.org/master/d7/d9f/tutorial_linux_install.html
CUDA_DOCS_URL=https://docs.nvidia.com/cuda/cuda-installation-guide-linux/index.html
NUMPY_DOCS_URL=https://numpy.org/install/
PANDAS_DOCS_URL=https://pandas.pydata.org/docs/getting_started/install.html
SKLEARN_DOCS_URL=https://scikit-learn.org/stable/install.html
KERAS_DOCS_URL=https://keras.io/getting_started/
MXNET_DOCS_URL=https://mxnet.apache.org/versions/1.9.1/get_started
JAX_DOCS_URL=https://github.com/google/jax#installation
TRANSFORMERS_DOCS_URL=https://huggingface.co/docs/transformers/installation
FASTAI_DOCS_URL=https://docs.fast.ai/#Installing
LIGHTGBM_DOCS_URL=https://lightgbm.readthedocs.io/en/latest/Installation-Guide.html
XGBOOST_DOCS_URL=https://xgboost.readthedocs.io/en/stable/install.html
SCIPY_DOCS_URL=https://scipy.org/install/
MATPLOTLIB_DOCS_URL=https://matplotlib.org/stable/users/installing/index.html
SEABORN_DOCS_URL=https://seaborn.pydata.org/installing.html
PLOTLY_DOCS_URL=https://plotly.com/python/getting-started/
SPACY_DOCS_URL=https://spacy.io/usage
NLTK_DOCS_URL=https://www.nltk.org/install.html
GENSIM_DOCS_URL=https://radimrehurek.com/gensim/install.html
OPENCV_PYTHON_DOCS_URL=https://pypi.org/project/opencv-python/
PILLOW_DOCS_URL=https://pillow.readthedocs.io/en/stable/installation.html
REQUESTS_DOCS_URL=https://requests.readthedocs.io/en/latest/user/install/
FLASK_DOCS_URL=https://flask.palletsprojects.com/en/2.3.x/installation/
DJANGO_DOCS_URL=https://docs.djangoproject.com/en/stable/topics/install/
FASTAPI_DOCS_URL=https://fastapi.tiangolo.com/tutorial/
STREAMLIT_DOCS_URL=https://docs.streamlit.io/library/get-started/installation
GRADIO_DOCS_URL=https://www.gradio.app/guides/quickstart

# =============================================================================
# System Scanner
# =============================================================================
SYSTEM_SCAN_TIMEOUT=60
ENABLE_GPU_DETECTION=true
ENABLE_CONTAINER_DETECTION=true
ENABLE_PACKAGE_SCANNING=true

# =============================================================================
# Security Scanning
# =============================================================================
ENABLE_SECURITY_SCANNING=true
VULNERABILITY_CHECK_ENABLED=true
LICENSE_CHECK_ENABLED=true
ALLOWED_LICENSES=MIT,Apache-2.0,BSD-3-Clause,BSD-2-Clause,ISC,GPL-3.0
BLOCKED_LICENSES=
VULNERABILITY_DB_URL=https://nvd.nist.gov/feeds/json/cve/1.1
OSV_API_URL=https://api.osv.dev/v1/query

# =============================================================================
# WebSocket / Real-time
# =============================================================================
WEBSOCKET_ENABLED=true
SOCKETIO_ENABLED=true
REALTIME_MAX_CONNECTIONS=100

# =============================================================================
# Database Migration
# =============================================================================
AUTO_MIGRATE_ON_STARTUP=false
MIGRATION_TIMEOUT=300

# =============================================================================
# Frontend
# =============================================================================
VUE_APP_API_URL=http://localhost:8000

# =============================================================================
# Performance
# =============================================================================
ENABLE_PERFORMANCE_MONITORING=true
ENABLE_QUERY_OPTIMIZATION=true
